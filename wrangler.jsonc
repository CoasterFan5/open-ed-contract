{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "open-ed-contract",
	"compatibility_date": "2026-04-07",
	"compatibility_flags": ["nodejs_compat"],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"build": {
		"command": "npx wrangler d1 migrations apply open-ed-contract --remote && pnpm run build"
	},

	"r2_buckets": [
		{
			"binding": "R2",
			"bucket_name": "sunlight-ledger-bucket"
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "open-ed-contract",
			"migrations_dir": "drizzle",
			"migrations_table": "__drizzle_migrations",
			"database_id": "b4270317-c075-4c28-94cf-84256803b7d6",
			"preview_database_id": "d",
			"remote": false
		}
	],
	"workers_dev": true,
	"preview_urls": true,
	"observability": {
		"enabled": true
	}
}
